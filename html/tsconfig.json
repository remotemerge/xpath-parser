{
  "compilerOptions": {
    // Basic Configuration
    "target": "ESNext",
    "module": "ESNext",
    "outDir": "../dist",
    "removeComments": true,
    "incremental": true,
    "types": ["bun"],

    // Strict Type Checking
    "strict": true,
    "noImplicitAny": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,

    // Module Resolution
    "moduleResolution": "bundler",

    // Performance and Optimization
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  // Include and Exclude
  "include": ["*.ts", "__tests__/**/*.ts", "makers/*.ts", "scripts/**/*.ts", "src/**/*.ts"],
  "exclude": ["../node_modules", "dist"]
}
