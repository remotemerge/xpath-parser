{
  "name": "@remotemerge/xpath-parser",
  "version": "1.4.1",
  "description": "Lightweight XPath parser for extracting structured data from HTML and XML documents.",
  "keywords": [
    "DOM",
    "Evaluate",
    "Parser",
    "XPath"
  ],
  "bugs": {
    "url": "https://github.com/remotemerge/xpath-parser/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Madan Sapkota",
    "email": "contact+gh@madansapkota.com",
    "url": "https://madansapkota.com",
    "role": "Maintainer"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remotemerge/xpath-parser.git"
  },
  "type": "module",
  "main": "../dist/node.cjs",
  "module": "../dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": {
        "import": "./dist/browser.mjs",
        "require": "./dist/browser.cjs"
      },
      "node": {
        "import": "./dist/node.mjs",
        "require": "./dist/node.cjs"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    },
    "./browser": {
      "types": "./dist/types/browser.d.ts",
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.cjs"
    },
    "./node": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.cjs"
    }
  },
  "scripts": {
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "test": "bun test",
    "dev": "vite --host 0.0.0.0 --port 3000",
    "preview": "vite preview",
    "build": "vite build && bun ./scripts/post-build.ts"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  },
  "engines": {
    "bun": ">=1.3.12"
  }
}
